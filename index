<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FIFA World Cup 2026™ - Official Ticketing</title>
    <meta name="description" content="Secure your official FIFA World Cup 2026™ match tickets. Browse matches, select seats, and book your World Cup experience.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Montserrat:wght@600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js">
    </script>
    <style>
        :root {
            --font-body: 'Inter', sans-serif;
            --font-heading: 'Montserrat', sans-serif;
            --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --glass-bg: rgba(255, 255, 255, 0.04);
            --glass-border: rgba(255, 255, 255, 0.1);
            --glass-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            --radius-sm: 12px;
            --radius: 16px;
            --radius-lg: 24px;
            --radius-xl: 32px;
            --gold: #c9a84c;
            --gold-light: #e0c76e;
            --gold-dark: #a07d2e;
            --blue-accent: #3b7ddd;
            --success: #2ecc71;
            --warning: #f39c12;
            --danger: #e74c3c;
            --info: #3498db;
        }
        [data-theme="dark"] {
            --bg-primary: #0a0a14;
            --bg-secondary: #111122;
            --bg-tertiary: #1a1a2e;
            --bg-card: #161630;
            --bg-glass: rgba(20, 20, 50, 0.6);
            --text-primary: #f0f0f5;
            --text-secondary: #c0c0d0;
            --text-muted: #8888a0;
            --border: rgba(255, 255, 255, 0.08);
            --border-strong: rgba(255, 255, 255, 0.15);
            --shadow-card: 0 4px 24px rgba(0, 0, 0, 0.4);
            --shadow-lg: 0 20px 60px rgba(0, 0, 0, 0.5);
            --overlay: rgba(0, 0, 0, 0.7);
            --input-bg: rgba(255, 255, 255, 0.05);
            --badge-bg: rgba(201, 168, 76, 0.15);
            --badge-text: #e0c76e;
            --nav-bg: rgba(10, 10, 20, 0.85);
        }
        [data-theme="light"] {
            --bg-primary: #f5f5f8;
            --bg-secondary: #ffffff;
            --bg-tertiary: #eef0f5;
            --bg-card: #ffffff;
            --bg-glass: rgba(255, 255, 255, 0.7);
            --text-primary: #1a1a2e;
            --text-secondary: #444460;
            --text-muted: #777790;
            --border: rgba(0, 0, 0, 0.08);
            --border-strong: rgba(0, 0, 0, 0.15);
            --shadow-card: 0 4px 20px rgba(0, 0, 0, 0.08);
            --shadow-lg: 0 16px 48px rgba(0, 0, 0, 0.12);
            --overlay: rgba(0, 0, 0, 0.5);
            --input-bg: rgba(0, 0, 0, 0.03);
            --badge-bg: rgba(180, 150, 40, 0.12);
            --badge-text: #8a6d20;
            --nav-bg: rgba(255, 255, 255, 0.9);
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        html {
            scroll-behavior: smooth;
            font-size: 16px;
        }
        body {
            font-family: var(--font-body);
            background: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.6;
            min-height: 100vh;
            transition: background var(--transition), color var(--transition);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }
        ::selection {
            background: var(--gold);
            color: #000;
        }
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg-secondary);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--border-strong);
            border-radius: 3px;
        }
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            background: var(--nav-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            padding: 0 2rem;
            height: 70px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: all var(--transition);
        }
        .navbar.scrolled {
            box-shadow: var(--shadow-lg);
            height: 62px;
        }
        .nav-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            font-family: var(--font-heading);
            font-weight: 800;
            font-size: 1.3rem;
            letter-spacing: -0.5px;
            color: var(--text-primary);
            text-decoration: none;
        }
        .nav-brand .trophy-icon {
            font-size: 1.6rem;
            color: var(--gold);
            animation: float 3s ease-in-out infinite;
        }
        @keyframes float {
            0%,
            100% {
                transform: translateY(0);
            }
            50% {
                transform: translateY(-6px);
            }
        }
        .nav-links {
            display: flex;
            gap: 0.5rem;
            align-items: center;
            list-style: none;
        }
        .nav-links a {
            color: var(--text-secondary);
            text-decoration: none;
            padding: 0.5rem 1rem;
            border-radius: 50px;
            font-weight: 500;
            font-size: 0.9rem;
            transition: all var(--transition);
            position: relative;
            white-space: nowrap;
        }
        .nav-links a:hover,
        .nav-links a.active {
            color: var(--text-primary);
            background: var(--glass-bg);
        }
        .nav-links a.active::after {
            content: '';
            position: absolute;
            bottom: 2px;
            left: 50%;
            transform: translateX(-50%);
            width: 20px;
            height: 3px;
            background: var(--gold);
            border-radius: 3px;
        }
        .nav-actions {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .btn-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 1px solid var(--border);
            background: var(--glass-bg);
            color: var(--text-primary);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all var(--transition);
            font-size: 1.1rem;
            position: relative;
        }
        .btn-icon:hover {
            border-color: var(--gold);
            color: var(--gold);
            box-shadow: 0 0 20px rgba(201, 168, 76, 0.2);
        }
        .cart-badge {
            position: absolute;
            top: -6px;
            right: -6px;
            background: var(--gold);
            color: #000;
            font-size: 0.7rem;
            font-weight: 700;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: popIn 0.3s ease;
        }
        @keyframes popIn {
            0% {
                transform: scale(0);
            }
            60% {
                transform: scale(1.3);
            }
            100% {
                transform: scale(1);
            }
        }
        .mobile-menu-btn {
            display: none;
            background: none;
            border: none;
            color: var(--text-primary);
            font-size: 1.5rem;
            cursor: pointer;
        }
        .page {
            display: none;
            padding-top: 70px;
            min-height: 100vh;
            animation: fadeSlideIn 0.4s ease;
        }
        .page.active {
            display: block;
        }
        @keyframes fadeSlideIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .container {
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 2rem;
        }
        .hero {
            position: relative;
            min-height: 90vh;
            display: flex;
            align-items: center;
            overflow: hidden;
            background: linear-gradient(135deg, #0a0a20 0%, #0d1a30 30%, #0a1a15 60%, #0a0a20 100%);
        }
        .hero-video-bg {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.35;
            pointer-events: none;
        }
        .hero-overlay {
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at center, transparent 30%, rgba(0, 0, 0, 0.7) 100%);
        }
        .hero-content {
            position: relative;
            z-index: 2;
            max-width: 700px;
            padding: 2rem;
        }
        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--badge-bg);
            color: var(--badge-text);
            padding: 0.5rem 1.2rem;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.85rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(201, 168, 76, 0.3);
            animation: pulse 2s ease-in-out infinite;
        }
        @keyframes pulse {
            0%,
            100% {
                box-shadow: 0 0 0 0 rgba(201, 168, 76, 0.4);
            }
            50% {
                box-shadow: 0 0 0 16px rgba(201, 168, 76, 0);
            }
        }
        .hero h1 {
            font-family: var(--font-heading);
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 900;
            line-height: 1.1;
            letter-spacing: -1px;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, #fff 0%, #e0c76e 50%, #fff 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .hero-subtitle {
            font-size: 1.2rem;
            color: var(--text-secondary);
            margin-bottom: 2rem;
            font-weight: 400;
        }
        .hero-btns {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 0.85rem 2rem;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            border: none;
            transition: all var(--transition);
            text-decoration: none;
            font-family: var(--font-body);
            letter-spacing: 0.3px;
        }
        .btn-primary {
            background: linear-gradient(135deg, var(--gold-dark), var(--gold), var(--gold-light));
            color: #000;
            box-shadow: 0 8px 30px rgba(201, 168, 76, 0.35);
        }
        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 14px 40px rgba(201, 168, 76, 0.5);
        }
        .btn-outline {
            background: transparent;
            border: 2px solid rgba(255, 255, 255, 0.5);
            color: #fff;
        }
        .btn-outline:hover {
            border-color: #fff;
            background: rgba(255, 255, 255, 0.08);
        }
        .btn-sm {
            padding: 0.5rem 1.2rem;
            font-size: 0.8rem;
            border-radius: 30px;
        }
        .btn-block {
            width: 100%;
            justify-content: center;
        }
        .countdown-section {
            background: var(--bg-secondary);
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
            padding: 2rem 0;
        }
        .countdown-grid {
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            flex-wrap: wrap;
        }
        .countdown-item {
            text-align: center;
            min-width: 80px;
        }
        .countdown-value {
            font-family: var(--font-heading);
            font-size: 3rem;
            font-weight: 900;
            color: var(--gold);
            line-height: 1;
            animation: countPulse 1s ease-in-out infinite;
        }
        .countdown-label {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--text-muted);
            margin-top: 0.3rem;
        }
        @keyframes countPulse {
            0%,
            100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.05);
            }
        }
        .section {
            padding: 4rem 0;
        }
        .section-header {
            text-align: center;
            margin-bottom: 3rem;
        }
        .section-title {
            font-family: var(--font-heading);
            font-size: 2.2rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            margin-bottom: 0.5rem;
        }
        .section-subtitle {
            color: var(--text-muted);
            font-size: 1rem;
        }
        .gold-underline {
            width: 60px;
            height: 4px;
            background: var(--gold);
            border-radius: 2px;
            margin: 1rem auto;
        }
        .match-cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 1.5rem;
        }
        .match-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            transition: all var(--transition);
            cursor: pointer;
            position: relative;
            box-shadow: var(--shadow-card);
        }
        .match-card:hover {
            transform: translateY(-6px);
            border-color: var(--gold);
            box-shadow: var(--shadow-lg), 0 0 40px rgba(201, 168, 76, 0.08);
        }
        .match-card-header {
            padding: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            background: var(--bg-tertiary);
        }
        .match-card .team {
            text-align: center;
            flex: 1;
        }
        .match-card .team-flag {
            font-size: 2.5rem;
            margin-bottom: 0.3rem;
        }
        .match-card .team-name {
            font-weight: 600;
            font-size: 0.85rem;
            color: var(--text-secondary);
        }
        .match-card .vs {
            font-weight: 900;
            font-size: 1rem;
            color: var(--text-muted);
            font-family: var(--font-heading);
        }
        .match-card-body {
            padding: 1.2rem 1.5rem;
        }
        .match-info-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 0.6rem;
            font-size: 0.85rem;
            color: var(--text-secondary);
        }
        .match-info-row i {
            width: 18px;
            color: var(--gold);
            text-align: center;
        }
        .match-card-footer {
            padding: 1rem 1.5rem;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .ticket-price {
            font-weight: 700;
            color: var(--gold);
            font-size: 1.1rem;
        }
        .availability-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
        }
        .availability-dot.high {
            background: var(--success);
            box-shadow: 0 0 8px var(--success);
        }
        .availability-dot.medium {
            background: var(--warning);
            box-shadow: 0 0 8px var(--warning);
        }
        .availability-dot.low {
            background: var(--danger);
            box-shadow: 0 0 8px var(--danger);
            animation: blink 0.8s infinite;
        }
        @keyframes blink {
            50% {
                opacity: 0.4;
            }
        }
        .city-cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
        }
        .city-card {
            background: var(--bg-card);
            border-radius: var(--radius-lg);
            overflow: hidden;
            border: 1px solid var(--border);
            transition: all var(--transition);
            cursor: pointer;
        }
        .city-card:hover {
            transform: translateY(-4px);
            border-color: var(--gold);
            box-shadow: var(--shadow-lg);
        }
        .city-card-img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            background: var(--bg-tertiary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4rem;
        }
        .city-card-body {
            padding: 1.2rem;
        }
        .city-card-body h4 {
            font-family: var(--font-heading);
            font-weight: 700;
            margin-bottom: 0.3rem;
        }
        .city-card-body .capacity {
            font-size: 0.85rem;
            color: var(--text-muted);
        }
        .search-section {
            background: var(--bg-secondary);
            padding: 1.5rem 0;
            position: sticky;
            top: 70px;
            z-index: 50;
            border-bottom: 1px solid var(--border);
            backdrop-filter: blur(10px);
        }
        .search-row {
            display: flex;
            gap: 0.8rem;
            flex-wrap: wrap;
            align-items: center;
        }
        .search-input,
        .search-select {
            padding: 0.7rem 1.2rem;
            border-radius: 50px;
            border: 1px solid var(--border-strong);
            background: var(--input-bg);
            color: var(--text-primary);
            font-family: var(--font-body);
            font-size: 0.9rem;
            transition: all var(--transition);
            min-width: 150px;
            flex: 1;
        }
        .search-input:focus,
        .search-select:focus {
            outline: none;
            border-color: var(--gold);
            box-shadow: 0 0 0 4px rgba(201, 168, 76, 0.1);
        }
        .ticket-detail-layout {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
        }
        @media (max-width: 900px) {
            .ticket-detail-layout {
                grid-template-columns: 1fr;
            }
        }
        .stadium-map {
            background: var(--bg-card);
            border-radius: var(--radius-lg);
            padding: 2rem;
            border: 1px solid var(--border);
            position: relative;
            overflow: hidden;
        }
        .seating-area {
            display: grid;
            grid-template-columns: repeat(8, 1fr);
            gap: 4px;
            max-width: 400px;
            margin: 0 auto;
        }
        .seat {
            aspect-ratio: 1;
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.2s;
            border: 1px solid transparent;
            font-size: 0.55rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: transparent;
            font-weight: 700;
        }
        .seat.cat1 {
            background: #c9a84c33;
            border-color: #c9a84c;
        }
        .seat.cat1:hover,
        .seat.cat1.selected {
            background: #c9a84c;
            color: #000;
            transform: scale(1.2);
            z-index: 2;
            box-shadow: 0 0 20px rgba(201, 168, 76, 0.6);
        }
        .seat.cat2 {
            background: #3b7ddd33;
            border-color: #3b7ddd;
        }
        .seat.cat2:hover,
        .seat.cat2.selected {
            background: #3b7ddd;
            color: #fff;
            transform: scale(1.2);
            z-index: 2;
            box-shadow: 0 0 20px rgba(59, 125, 221, 0.6);
        }
        .seat.cat3 {
            background: #2ecc7133;
            border-color: #2ecc71;
        }
        .seat.cat3:hover,
        .seat.cat3.selected {
            background: #2ecc71;
            color: #000;
            transform: scale(1.2);
            z-index: 2;
            box-shadow: 0 0 20px rgba(46, 204, 113, 0.6);
        }
        .seat.vip {
            background: #e74c3c33;
            border-color: #e74c3c;
        }
        .seat.vip:hover,
        .seat.vip.selected {
            background: #e74c3c;
            color: #fff;
            transform: scale(1.2);
            z-index: 2;
            box-shadow: 0 0 20px rgba(231, 76, 60, 0.6);
        }
        .seat.taken {
            background: #555;
            border-color: #444;
            cursor: not-allowed;
            opacity: 0.4;
        }
        .cart-overlay {
            position: fixed;
            inset: 0;
            background: var(--overlay);
            z-index: 2000;
            opacity: 0;
            pointer-events: none;
            transition: opacity var(--transition);
        }
        .cart-overlay.open {
            opacity: 1;
            pointer-events: all;
        }
        .cart-sidebar {
            position: fixed;
            top: 0;
            right: -450px;
            width: 100%;
            max-width: 420px;
            height: 100vh;
            background: var(--bg-secondary);
            z-index: 2001;
            transition: right var(--transition);
            display: flex;
            flex-direction: column;
            box-shadow: var(--shadow-lg);
            border-left: 1px solid var(--border);
        }
        .cart-sidebar.open {
            right: 0;
        }
        .cart-header {
            padding: 1.5rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .cart-items {
            flex: 1;
            overflow-y: auto;
            padding: 1rem;
        }
        .cart-item {
            display: flex;
            gap: 1rem;
            padding: 1rem;
            background: var(--bg-card);
            border-radius: var(--radius);
            margin-bottom: 0.8rem;
            border: 1px solid var(--border);
            align-items: center;
        }
        .cart-item-info {
            flex: 1;
            font-size: 0.85rem;
        }
        .cart-item-qty {
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .cart-item-qty button {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 1px solid var(--border);
            background: var(--glass-bg);
            color: var(--text-primary);
            cursor: pointer;
            font-weight: 700;
            transition: all var(--transition);
        }
        .cart-item-qty button:hover {
            border-color: var(--gold);
            color: var(--gold);
        }
        .cart-footer {
            padding: 1.5rem;
            border-top: 1px solid var(--border);
        }
        .cart-total-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
        }
        .cart-total-row.grand {
            font-weight: 700;
            font-size: 1.2rem;
            margin-top: 0.5rem;
            padding-top: 0.5rem;
            border-top: 1px solid var(--border);
        }
        .form-group {
            margin-bottom: 1.2rem;
        }
        .form-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 0.4rem;
            font-size: 0.85rem;
            color: var(--text-secondary);
        }
