            function addToCart(matchId, category = 'Category 3', price = null, seatId = null) {
                const match = matches.find(m => m.id === matchId);
                if (!match) return;
                const ticketPrice = price || match.price;
                const existing = cart.find(item => item.matchId === matchId && item.category === category && item.seatId === seatId);
                if (existing) {
                    existing.qty += 1;
                } else {
                    cart.push({ matchId, category, price: ticketPrice, seatId: seatId || 'GA-' + Date.now(), qty: 1, match: {...match} });
                }
                saveCart();
                showToast('✅ Ticket added to cart!');
                renderCart();
                if (!document.getElementById('cartSidebar').classList.contains('open')) toggleCart();
            }

            function removeFromCart(index) {
                cart.splice(index, 1);
                saveCart();
                renderCart();
                showToast('🗑️ Item removed');
            }

            function updateCartQty(index, delta) {
                if (cart[index].qty + delta <= 0) {
                    removeFromCart(index);
                    return;
                }
                cart[index].qty += delta;
                saveCart();
                renderCart();
            }

            function saveCart() {
                localStorage.setItem('fifa_cart', JSON.stringify(cart));
                updateCartBadge();
