                const container = document.getElementById('allMatches');
                const data = filtered || matches;
                container.innerHTML = data.map(m => renderMatchCard(m)).join('');
                document.getElementById('noMatchesMsg').style.display = data.length === 0 ? 'block' : 'none';
            }

            function populateSearchFilters() {
                const citySelect = document.getElementById('searchCity');
                const stadiumSelect = document.getElementById('searchStadium');
                citySelect.innerHTML = '<option value="">All Cities</option>' + cities.map(c => `<option value="${c.name}">${c.name}</option>`).join('');
                const uniqueStadiums = [...new Set(matches.map(m => m.stadium))];
                stadiumSelect.innerHTML = '<option value="">All Stadiums</option>' + uniqueStadiums.map(s => `<option value="${s}">${s}</option>`).join('');
            }

            function filterMatches() {
                const team = document.getElementById('searchTeam').value.toLowerCase();
                const city = document.getElementById('searchCity').value;
                const stadium = document.getElementById('searchStadium').value;
                const date = document.getElementById('searchDate').value;
                const filtered = matches.filter(m => {
                    if (team && !(m.home.name+' '+m.away.name+' '+m.home.code+' '+m.away.code).toLowerCase().includes(team)) return false;
                    if (city && m.city.name !== city) return false;
                    if (stadium && m.stadium !== stadium) return false;
                    if (date && m.date !== date) return false;
                    return true;
                });
                renderAllMatches(filtered);
            }

            function viewTicketDetail(matchId) {
                const match = matches.find(m => m.id === matchId);
                if (!match) return;
                currentPage = 'ticket-detail';
                document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
                document.getElementById('page-ticket-detail').classList.add('active');
                selectedSeats = [];
                const content = document.getElementById('ticketDetailContent');
                content.innerHTML = `
              <div>
                <button class="btn btn-outline btn-sm" style="margin-bottom:1rem;" onclick="navigateTo('matches')">← Back to Matches</button>
                <div class="glass-card">
                  <div style="display:flex;gap:2rem;align-items:center;flex-wrap:wrap;margin-bottom:1.5rem;">
                    <div style="font-size:3rem;">${match.home.flag}</div>
                    <div style="text-align:center;"><h2 style="font-family:var(--font-heading);">${match.home.name} vs ${match.away.name}</h2><p style="color:var(--text-muted);">${match.group}</p></div>
                    <div style="font-size:3rem;">${match.away.flag}</div>
                  </div>
                  <div class="match-info-row"><i class="fas fa-calendar"></i> <strong>${match.date}</strong> at ${match.time}</div>
                  <div class="match-info-row"><i class="fas fa-map-marker-alt"></i> ${match.stadium}, ${match.city.name}</div>
                  <div class="match-info-row"><i class="fas fa-users"></i> Capacity: ${match.city.capacity}</div>
                  <div style="margin-top:1rem;"><span class="availability-dot ${match.availability}"></span> <strong>${match.availability==='high'?'Available':match.availability==='medium'?'Selling Fast':'Limited Tickets!'}</strong></div>
                </div>
                <div style="margin-top:1.5rem;">
                  <h4 style="font-family:var(--font-heading);margin-bottom:1rem;">Ticket Categories</h4>
                  ${['Category 1','Category 2','Category 3','VIP Hospitality'].map((cat,i)=>{
                    const prices=[match.price*2.5,match.price*1.6,match.price,match.price*5];
                    const benefits=['Premium center seats, lounge access','Great views, comfortable seating','Standard seating, great value','VIP lounge, catering, best views'];
                    const stock=[Math.floor(Math.random()*50)+5,Math.floor(Math.random()*100)+10,Math.floor(Math.random()*200)+20,Math.floor(Math.random()*10)+2];
                    return `<div class="glass-card" style="margin-bottom:0.8rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;">
                      <div><strong>${cat}</strong><div style="font-size:0.8rem;color:var(--text-muted);">${benefits[i]}</div><div style="font-size:0.75rem;color:var(--text-muted);">${stock} tickets left</div></div>
                      <div style="text-align:right;"><div style="font-weight:700;color:var(--gold);font-size:1.2rem;">${formatPrice(prices[i])}</div>
                      <button class="btn btn-primary btn-sm" onclick="addToCart(${match.id},'${cat}',${prices[i]})">Add to Cart</button></div>
                    </div>`;
                  }).join('')}
                </div>
              </div>
              <div class="stadium-map glass-card">
                <h4 style="font-family:var(--font-heading);text-align:center;margin-bottom:1rem;">🏟️ Interactive Seating Map</h4>
                <p style="text-align:center;color:var(--text-muted);font-size:0.8rem;margin-bottom:1rem;">Click seats to select — <span style="color:#c9a84c;">Cat 1</span> | <span style="color:#3b7ddd;">Cat 2</span> | <span style="color:#2ecc71;">Cat 3</span> | <span style="color:#e74c3c;">VIP</span></p>
                <div class="seating-area" id="seatingArea"></div>
                <p style="text-align:center;margin-top:1rem;font-size:0.8rem;color:var(--text-muted);">Selected: <span id="selectedSeatInfo">None</span></p>
                <button class="btn btn-primary btn-block" style="margin-top:0.5rem;" id="btnSelectSeats" disabled onclick="addSelectedSeats(${match.id})">Add Selected Seats to Cart</button>
              </div>`;
                setTimeout(() => {
                    const seatingArea = document.getElementById('seatingArea');
                    let seatsHTML = '';
                    for (let i = 0; i < 64; i++) {
                        const cat = i < 16 ? 'vip' : i < 32 ? 'cat1' : i < 48 ? 'cat2' : 'cat3';
                        const taken = Math.random() < 0.3;
                        seatsHTML += `<div class="seat ${cat} ${taken?'taken':''}" data-seat="${i}" data-cat="${cat}" onclick="${taken?'':'selectSeat(this)'}">${i+1}</div>`;
                    }
                    seatingArea.innerHTML = seatsHTML;
                }, 200);
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }

            function selectSeat(el) {
                if (el.classList.contains('taken')) return;
                el.classList.toggle('selected');
                const seatId = el.dataset.seat;
                const cat = el.dataset.cat;
                if (el.classList.contains('selected')) {
                    selectedSeats.push({ seatId, cat });
                } else {
                    selectedSeats = selectedSeats.filter(s => s.seatId !== seatId);
                }
                document.getElementById('selectedSeatInfo').textContent = selectedSeats.length > 0 ? selectedSeats.map(s => `Seat ${parseInt(s.seatId)+1} (${s.cat})`).join(', ') : 'None';
                document.getElementById('btnSelectSeats').disabled = selectedSeats.length === 0;
            }

            function addSelectedSeats(matchId) {
                const match = matches.find(m => m.id === matchId);
                if (!match || selectedSeats.length === 0) return;
                const prices = { vip: match.price*5, cat1: match.price*2.5, cat2: match.price*1.6, cat3: match.price };
                const names = { vip: 'VIP Hospitality', cat1: 'Category 1', cat2: 'Category 2', cat3: 'Category 3' };
                selectedSeats.forEach(s => addToCart(matchId, names[s.cat], prices[s.cat], s.seatId));
                selectedSeats = [];
                document.getElementById('selectedSeatInfo').textContent = 'None';
                document.getElementById('btnSelectSeats').disabled = true;
                document.querySelectorAll('.seat.selected').forEach(s => s.classList.remove('selected'));
                if (document.getElementById('cartSidebar').classList.contains('open')) renderCart();
            }

            function renderCityCards() {
                document.getElementById('cityCards').innerHTML = cities.map(c => `
              <div class="city-card">
                <div class="city-card-img">${c.icon}</div>
                <div class="city-card-body"><h4>${c.name}</h4><p>🏟️ ${c.stadium}</p><p class="capacity">Capacity: ${c.capacity} | ${c.country}</p></div>
              </div>`).join('');
            }

            function updateCountdown() {
                const target = new Date('2026-06-11T15:00:00-04:00').getTime();
                const diff = Math.max(0, target - Date.now());
                document.getElementById('countDays').textContent = String(Math.floor(diff/(1000*60*60*24))).padStart(2,'0');
                document.getElementById('countHours').textContent = String(Math.floor((diff/(1000*60*60))%24)).padStart(2,'0');
                document.getElementById('countMins').textContent = String(Math.floor((diff/(1000*60))%60)).padStart(2,'0');
                document.getElementById('countSecs').textContent = String(Math.floor((diff/1000)%60)).padStart(2,'0');
            }

            function showToast(msg) {
                const t = document.createElement('div'); t.className='toast'; t.textContent=msg;
                document.getElementById('toastContainer').appendChild(t);
                setTimeout(()=>t.remove(),3000);
            }

            function renderAll() {
                renderFeaturedMatches(); renderCityCards(); renderCart(); updateCartBadge(); updateCountdown();
                if (currentPage==='matches'){populateSearchFilters();renderAllMatches();}
                if (currentPage==='checkout') renderCheckout();
                if (currentPage==='dashboard') renderDashboard();
            }

            function init() {
                initTheme();
                renderFeaturedMatches(); renderCityCards(); updateCartBadge(); updateCountdown();
                setInterval(updateCountdown,1000);
                window.addEventListener('scroll',()=>document.getElementById('navbar').classList.toggle('scrolled',window.scrollY>50));
                document.addEventListener('click',e=>{if(!e.target.closest('.navbar')&&document.getElementById('navLinks').classList.contains('show'))document.getElementById('navLinks').classList.remove('show');});
                document.addEventListener('keydown',e=>{
                    if(e.key==='Escape'){
                        if(document.getElementById('cartSidebar').classList.contains('open')) toggleCart();
                        if(document.getElementById('qrModal').classList.contains('open')) closeQRModal();
                    }
                });
                updateCartBadge();
            }

            window.navigateTo = navigateTo;
            window.toggleTheme = toggleTheme;
            window.toggleCart = toggleCart;
            window.toggleMobileMenu = toggleMobileMenu;
            window.addToCart = addToCart;
            window.removeFromCart = removeFromCart;
            window.updateCartQty = updateCartQty;
            window.viewTicketDetail = viewTicketDetail;
            window.selectSeat = selectSeat;
            window.addSelectedSeats = addSelectedSeats;
            window.showQRModal = showQRModal;
            window.closeQRModal = closeQRModal;
            window.processCheckout = processCheckout;
            window.switchDashTab = switchDashTab;
            window.updateCurrency = updateCurrency;
            window.filterMatches = filterMatches;
            init();
        })();
    </script>
</body>
</html>
